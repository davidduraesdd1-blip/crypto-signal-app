# .streamlit/secrets.toml.example
# Copy this file to .streamlit/secrets.toml and fill in your keys.
# secrets.toml is gitignored — never commit the real file.
#
# Key rotation tiers:
#   Tier 1 (critical — rotate immediately if leaked): ANTHROPIC_API_KEY
#   Tier 2 (high — rotate within 24h): SUPERGROK_SENTRY_DSN
#   Tier 3 (medium — rotate within 1 week): CRYPTOPANIC_API_KEY, SUPERGROK_COINGECKO_API_KEY
#   Tier 4 (low — rotate at next cycle): FRED_API_KEY

# ─── Tier 1: AI / LLM ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY = ""          # https://console.anthropic.com/

# ─── Tier 2: Infrastructure ───────────────────────────────────────────────────
SUPERGROK_SENTRY_DSN = ""       # https://sentry.io/  (free tier)

# ─── Tier 3: Market Data ──────────────────────────────────────────────────────
CRYPTOPANIC_API_KEY = ""        # https://cryptopanic.com/developers/api/  (free tier)
SUPERGROK_COINGECKO_API_KEY = "" # https://www.coingecko.com/en/api  (Pro)
FRED_API_KEY = ""               # https://fred.stlouisfed.org/docs/api/api_key.html  (free)
