# Polaris Edge — local dev env vars
#
# Copy this file to `.env.local` (also gitignored) before running:
#   - `npm run dev`         (local Next.js against Render backend)
#   - `npm run build:mobile` (Capacitor static export)
#
# DO NOT commit `.env.local` — it's gitignored by design.
# DO NOT mark these as "Sensitive" in the Vercel UI — Sensitive blocks
# NEXT_PUBLIC_* inlining (Phase D 2026-05-04 incident, see
# docs/audits/2026-05-05_cross-platform-connectivity.md).

# Backend base URL — production Render or local FastAPI on :8000
NEXT_PUBLIC_API_BASE=https://crypto-signal-app-1fsi.onrender.com

# API key — must match CRYPTO_SIGNAL_API_KEY on Render. NEXT_PUBLIC_*
# is inlined into the JS bundle on build. Acceptable trade-off for the
# D4-D8 window where the only consumer is David. Real auth (NextAuth +
# JWT) is a post-launch hardening item.
NEXT_PUBLIC_API_KEY=<paste-from-Render-env-CRYPTO_SIGNAL_API_KEY>
