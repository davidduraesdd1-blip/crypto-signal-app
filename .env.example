# ══════════════════════════════════════════════════════════════════════════════
# SuperGrok Mathematically Model — Environment Variables
# Copy this file to .env and fill in your keys. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── AI (HIGH VALUE — unlocks signal explanations, weight adjustments, agent) ──
ANTHROPIC_API_KEY=sk-ant-api03-...          # console.anthropic.com → API Keys
ANTHROPIC_ENABLED=true                      # set to "false" to disable all AI features without removing key

# ── Market Data ───────────────────────────────────────────────────────────────
SUPERGROK_COINGECKO_API_KEY=CG-...          # coingecko.com/en/api (free demo tier available)
COINMARKETCAP_API_KEY=...                   # coinmarketcap.com/api (free, 333 req/day) — CMC global metrics panel

# ── Wallet & Portfolio ────────────────────────────────────────────────────────
ZERION_API_KEY=...                          # zerion.io/developers — wallet portfolio tab

# ── Live Trading (OKX) — leave blank to stay in paper-trade mode ─────────────
OKX_API_KEY=...                             # OKX account → API Management
OKX_SECRET=...
OKX_PASSPHRASE=...

# ── Optional: Premium On-Chain Data ──────────────────────────────────────────
SUPERGROK_COINALYZE_API_KEY=...             # coinalyze.net — aggregated funding rates & OI
ETHERSCAN_API_KEY=...                       # etherscan.io/register (free) — wallet tx lookup

# ── Error Monitoring ──────────────────────────────────────────────────────────
SUPERGROK_SENTRY_DSN=https://...@sentry.io/...   # sentry.io (free tier)

# ── Optional: Additional Paid Data Sources ────────────────────────────────────
# Set these in the Config Editor tab in the UI, or here as env vars:
# LUNARCRUSH_API_KEY=...                    # lunarcrush.com/developers — social sentiment
# GLASSNODE_API_KEY=...                     # glassnode.com — on-chain analytics
# CRYPTOQUANT_API_KEY=...                   # cryptoquant.com — exchange flow data
# COINGLASS_API_KEY=...                     # coinglass.com — liquidation data

# ── Optional: News & Fundraising (improve free-tier rate limits with key) ────
# CRYPTOPANIC_API_KEY=...                   # cryptopanic.com (free; key bumps from 50/24h to 50k/month)
# CRYPTORANK_API_KEY=...                    # cryptorank.io (token unlocks + VC fundraising)
